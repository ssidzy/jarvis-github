{
  "name": "jarvis-email-assistant",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:frontend": "vite --port 5173",
    "build": "vite build",
    "build:backend": "tsc --outDir dist-server --module commonjs --target ES2022 --skipLibCheck server.ts || echo 'Use tsx directly'",
    "start": "NODE_ENV=production tsx server.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "deploy:s3": "npm run build && aws s3 sync dist/ s3://$S3_BUCKET --delete"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "fuzzball": "^2.2.3",
    "gsap": "^3.14.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "ogl": "^1.0.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
