# ─────────────────────────────────────────────────────────────────────────────
# Jarvis Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets!

# ─── Backend Configuration ────────────────────────────────────────────────────

# OpenAI API Key (required for email generation)
OPENAI_API_KEY=sk-...your-key-here...

# OpenAI Model (optional, defaults to gpt-4o-mini)
# Options: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# Express server port (optional, defaults to 3000)
PORT=3000

# CORS: Allowed frontend origins (comma-separated)
# Development: http://localhost:5173,http://localhost:3000
# Production:  https://yourapp.com,https://www.yourapp.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Admin key for password migration endpoint (generate a random string)
ADMIN_KEY=your-secure-random-admin-key-here

# ─── Frontend Configuration (Vite) ────────────────────────────────────────────
# These are exposed to the browser — NO SECRETS!

# Backend API URL
# Development: Leave empty (Vite proxy handles /api → localhost:3000)
# Production:  https://api.yourapp.com
VITE_API_BASE_URL=

# Base path for the app
# Custom domain: /
# GitHub Pages:  /your-repo-name/
VITE_BASE_PATH=/
