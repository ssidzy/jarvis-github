# .env.production — committed to repo (no secrets here)
# Vite reads this at build time for the frontend bundle
# ─────────────────────────────────────────────────────────────────────────────

# Backend API URL - Update this to your EC2 backend URL
# Examples:
#   AWS EC2: https://api.yourapp.com
#   Fly.io:  https://jarvis-github.fly.dev
VITE_API_BASE_URL=https://api.sidzy.in

# Base path — '/' for custom domain, '/repo-name/' for GitHub Pages
VITE_BASE_PATH=/
