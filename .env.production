# .env.production — committed to repo (no secrets here)
# Vite reads this at build time for the frontend bundle
# ─────────────────────────────────────────────────────────────────────────────

# Backend API URL - Empty since frontend and backend on same domain (sidzy.in)
# Frontend served from same server, so relative paths work: /api/auth/login
VITE_API_BASE_URL=

# Base path — '/' for custom domain, '/repo-name/' for GitHub Pages
VITE_BASE_PATH=/
